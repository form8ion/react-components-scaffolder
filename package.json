{
  "name": "@form8ion/react-components-scaffolder",
  "description": "opinionated scaffolder for React component-library projects",
  "license": "MIT",
  "version": "0.0.0-semantically-released",
  "type": "module",
  "author": "Matt Travi <npm@travi.org> (https://matt.travi.org/)",
  "repository": "form8ion/react-components-scaffolder",
  "bugs": "https://github.com/form8ion/react-components-scaffolder/issues",
  "homepage": "https://npm.im/@form8ion/react-components-scaffolder",
  "main": "./lib/index.js",
  "exports": "./lib/index.js",
  "sideEffects": false,
  "scripts": {
    "pretest": "run-s build",
    "test": "npm-run-all --print-label --parallel lint:* --parallel test:*",
    "lint:lockfile": "lockfile-lint",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "run-s 'lint:js -- --fix'",
    "lint:md": "remark . --frail",
    "lint:sensitive": "ban",
    "lint:peer": "npm ls >/dev/null",
    "clean": "rimraf ./lib",
    "prebuild": "run-s clean",
    "build": "npm-run-all --print-label --parallel build:*",
    "build:js": "rollup --config",
    "watch": "run-s 'build:js -- --watch'",
    "prepack": "run-s build",
    "test:unit": "cross-env NODE_ENV=test c8 run-s test:unit:base",
    "test:unit:base": "DEBUG=any vitest run",
    "lint:gherkin": "gherkin-lint",
    "test:integration": "run-s 'test:integration:base -- --profile noWip'",
    "test:integration:base": "DEBUG=any cucumber-js test/integration",
    "test:integration:debug": "DEBUG=test run-s test:integration",
    "test:integration:wip": "run-s 'test:integration:base -- --profile wip'",
    "test:integration:focus": "run-s 'test:integration:base -- --profile focus'",
    "prepare": "husky install",
    "lint:publish": "publint --strict"
  },
  "files": [
    "lib/",
    "templates/"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "packageManager": "npm@11.7.0+sha512.c22099a6fff8d5b2286c2a09df5352b4858a7c0c716320f58989d60ad8b29ecf2ce6fdfe97ccb41c23ffb1272e1fa079f868487dd6b81d02a2a9e199c095a117",
  "dependencies": {
    "@form8ion/cypress-scaffolder": "4.0.0",
    "deepmerge": "^4.2.2",
    "make-dir": "^4.0.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "12.5.0",
    "@form8ion/commitlint-config": "2.0.8",
    "@form8ion/eslint-config": "7.0.13",
    "@form8ion/eslint-config-cucumber": "1.4.1",
    "@form8ion/eslint-config-vitest": "1.0.0",
    "@form8ion/remark-lint-preset": "6.0.7",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@travi/any": "3.1.3",
    "ban-sensitive-files": "1.10.11",
    "c8": "10.1.3",
    "cross-env": "7.0.3",
    "cz-conventional-changelog": "3.3.0",
    "gherkin-lint": "4.2.4",
    "husky": "9.1.7",
    "lockfile-lint": "4.14.1",
    "npm-run-all2": "7.0.2",
    "publint": "0.3.16",
    "remark-cli": "12.0.1",
    "rimraf": "6.1.2",
    "rollup": "4.54.0",
    "rollup-plugin-auto-external": "2.0.0",
    "vitest": "4.0.16",
    "vitest-when": "0.10.0"
  }
}
